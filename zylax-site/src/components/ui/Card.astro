---
/**
 * Card.astro — Surface élevée avec border subtile et hover effect.
 */
export interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = true } = Astro.props;

const base = 'bg-[var(--bg-elevated)] border border-[var(--border)] p-8';
const hoverClasses = hover ? 'transition-colors duration-200 hover:border-[var(--border-strong)]' : '';

const classes = [base, hoverClasses, className].join(' ');
---

<div class={classes}>
  <slot />
</div>
