---
/**
 * CTAFinal.astro — Appel à l'action final après la section À propos
 * Encourage l'utilisateur à réserver une démo ou à consulter la FAQ
 */
import Button from './ui/Button.astro';
const CALENDLY = 'https://calendly.com/zylaxyanis/new-meeting';
---

<section id="cta-final" class="section" style="border-top: 1px solid var(--border); text-align: center;">
  <div class="container">

    <p class="eyebrow reveal">Prêt à automatiser votre support ?</p>

    <h2
      class="heading-display reveal"
      style="font-size: clamp(36px, 5vw, 64px); line-height: 1.05; margin-bottom: 24px; margin-top: 16px; max-width: 560px;"
    >
      Commencez en moins de 5 jours — sans engagement.
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary);
             max-width: 560px; margin: 0 auto 32px;"
    >
      Nous konfigurons votre moteur RAG, le connectons à Zendesk ou Intercom,
      et vous livrons un premier bot fonctionnel en moins d’une semaine.
    </p>

    <div class="reveal" style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <Button variant="primary" href={CALENDLY} target="_blank" rel="noopener noreferrer">
        Réserver votre appel de démarrage →
      </Button>
      <Button variant="secondary" href="#faq">
        Voir la FAQ ↓
      </Button>
    </div>

  </div>
</section>