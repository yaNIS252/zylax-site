---
/**
 * Logo.astro — Logo Zylax (monogramme Z chrome, PNG transparent).
 *
 * Props :
 *   height  : hauteur en px (défaut 32). La largeur suit le ratio carré.
 *   class   : classes CSS additionnelles
 */
export interface Props {
  height?: number;
  class?: string;
}

const { height = 32, class: className = '' } = Astro.props;

import logoImg from '../assets/logo.png';
import { Image } from 'astro:assets';

// Scale width to maintain aspect ratio based on desired height
const scale = height / logoImg.height;
const width = Math.round(logoImg.width * scale);
---
<Image
  src={logoImg.src}
  alt="Zylax"
  width={width}
  height={height}
  class={className}
  loading="eager"
  decoding="async"
  style={`height: ${height}px; width: auto;`}
/>