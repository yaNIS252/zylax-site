---
/**
 * Icp.astro — Profil client idéal (ICP)
 * Présente les caractéristiques des clients auxquels Zylax apporte le plus de valeur
 */

const icpGroups = [
  {
    title: 'SaaS B2B Européen',
    description: 'Entreprises de 50 à 500 employés avec une documentation technique riche et un support client interne.',
    icon: '🇪🇺',
    badge: 'IDÉAL',
    badgeColor: 'var(--score-high)'
  },
  {
    title: 'Support Technique Complexe',
    description: 'Produits nécessitant une expertise technique avancée avec des questions récurrentes sur configuration, intégration et dépannage.',
    icon: '🔧',
    badge: 'HAUTE VALEUR',
    badgeColor: 'var(--score-mid)'
  },
  {
    title: 'Volume de Tickets Élevé',
    description: 'Plus de 500 tickets mensuels avec au moins 40% de questions répétitives pouvant être automatisées.',
    icon: '📊',
    badge: 'ROI RAPIDE',
    badgeColor: 'var(--score-high)'
  }
];

const values = [
  { label: 'Documents techniques', value: 'Confluence, Notion, GitBook, Zendesk Guide' },
  { label: 'Stack support', value: 'Zendesk, Intercom, Freshdesk, Salesforce Service Cloud' },
  { label: 'Volume mensuel', value: '500 - 5 000 tickets' },
  { label: 'Taux de répétition', value: '40 - 70%' },
  { label: 'Équipe support', value: '5 - 50 agents L1/L2' }
];
---

<section id="icp" class="section" style="border-top: 1px solid var(--border);">
  <div class="container">

    <p class="eyebrow reveal">PROFIL CLIENT IDÉAL</p>

    <h2
      class="heading-display reveal"
      style="font-size: clamp(36px, 5vw, 64px); line-height: 1.05; margin-bottom: 40px; margin-top: 16px; max-width: 720px;"
    >
      Pour quelles entreprises Zylax crée-t-il le plus d'impact ?
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary); max-width: 700px; margin-bottom: 64px;"
    >
      Zylax est conçu pour les entreprises SaaS B2B qui rencontrent un défi spécifique de support client.
      Nous maximisons notre valeur lorsque votre documentation est complète mais sous-utilisée, et que
      vos agents passent trop de temps sur des questions récurrentes plutôt que sur des problèmes complexes.
    </p>

    <!-- ICP Groups -->
    <div class="reveal" style="display: grid; gap: 24px; margin-bottom: 48px;">
      {icpGroups.map((group, i) => (
        <div
          key={i}
          style={`border: 1px solid var(--border);
                  border-radius: 8px;
                  padding: 24px;
                  background: var(--bg-elevated);
                  display: flex;
                  flex-direction: column;
                  align-items: flex-start;
                  gap: 16px;`}
        >
          <div style="display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 36px;">{group.icon}</span>
            <span style={`font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em;
                          color: ${group.badgeColor}; background: rgba(255,255,255,0.05);
                          padding: 2px 8px; border-radius: 3px;`}>
              {group.badge}
            </span>
          </div>
          <h3 style="font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 600; color: var(--text); margin: 0;">
            {group.title}
          </h3>
          <p style="font-size: 15px; color: var(--text-secondary); line-height: 1.6;">
            {group.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Key Values Table -->
    <div class="reveal" style="border: 1px solid var(--border); overflow: hidden;">
      {/* Header */}
      <div style="display: grid; grid-template-columns: 1fr 1fr; padding: 14px 24px;
                  background: var(--bg-elevated); border-bottom: 1px solid var(--border);">
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">Critère</span>
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">Valeur typique</span>
      </div>

      {/* Rows */}
      {values.map((value, i) => (
        <div
          key={i}
          style={`display: grid; grid-template-columns: 1fr 1fr; padding: 16px 24px;
                  align-items: center;
                  ${i < values.length - 1 ? 'border-bottom: 1px solid var(--border);' : ''}`}
        >
          <span style={`font-size: 14px; color: var(--text-secondary);`}>
            {value.label}
          </span>
          <span style={`font-size: 14px; font-family: 'Syne', sans-serif; font-weight: 500; color: var(--text);`}>
            {value.value}
          </span>
        </div>
      ))}
    </div>

    <!-- Call to action -->
    <p
      class="reveal"
      style="margin-top: 32px; font-size: 18px; font-weight: 500; color: var(--text);
             max-width: 500px; line-height: 1.5;
             padding-left: 20px; border-left: 2px solid var(--border-strong);"
    >
      Vous reconnaissez votre entreprise dans ce profil ? <span style="color: var(--text-secondary);">Réservons une démo pour vérifier l'adéquation.</span>
    </p>

  </div>
</section>