---
/**
 * Hero.astro — Section hero principale.
 * Logo Z en watermark arrière-plan, H1 centré, stats animées au scroll.
 */
import Button from './ui/Button.astro';
import logoImg from '../assets/logo.png';
import { Image } from 'astro:assets';

const CALENDLY = 'https://calendly.com/zylaxyanis/new-meeting';

const stats = [
  { value: '70',  suffix: ' %', label: 'TICKETS L1 RÉSOLUS AUTOMATIQUEMENT' },
  { value: '2',   prefix: '< ', suffix: ' s', label: 'TEMPS DE RÉPONSE MOYEN' },
  { value: '5',   suffix: ' jours', label: "D'ONBOARDING JUSQU'EN PRODUCTION" },
];

---

<section
  id="hero"
  style="position: relative; overflow: hidden;
         padding-top: 160px; padding-bottom: 160px;
         display: flex; flex-direction: column; align-items: center;
         text-align: center;"
>
  <!-- Mesh gradient background -->
  <div class="hero-bg" aria-hidden="true"></div>
  <!-- Logo Z watermark — grand, centré, très transparent -->
  <div
    aria-hidden="true"
    style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
           pointer-events: none; z-index: 0; overflow: hidden;"
  >
    <Image
      src={logoImg.src}
      alt=""
      width={logoImg.width}
      height={logoImg.height}
      style="width: min(600px, 90vw); opacity: 0.04; filter: grayscale(100%);
             transform: scale(1.05);
             user-select: none;"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <!-- Contenu hero — au-dessus du watermark -->
  <div class="container" style="position: relative; z-index: 1; max-width: 880px;">

    <!-- Eyebrow -->
    <p class="eyebrow reveal">RAG SUPPORT CLIENT &nbsp;·&nbsp; SAAS B2B FRANCOPHONE <span class="badge">BETA</span></p>

    <!-- H1 -->
    <h1
      class="heading-display reveal hero-h1"
      style="font-size: clamp(52px, 8vw, 96px); line-height: 1.0; letter-spacing: -0.025em; font-weight: 800;
             margin-bottom: 28px; margin-top: 16px;"
    >
      <span class="hero-gradient">70%</span> de vos tickets support, résolus par une IA qui a vraiment lu votre doc.
    </h1>

    <!-- Subline -->
    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.6; color: var(--text-secondary);
             margin-bottom: 40px;"
    >
      Pas un chatbot scripté. Un agent connecté à votre documentation Zendesk ou Intercom, opérationnel en 5 jours.
    </p>

    <!-- CTA group -->
    <div class="reveal" style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 96px;">
      <Button variant="primary" href={CALENDLY} target="_blank" rel="noopener noreferrer" class="hero-cta-primary">
        Réserver une démo 20 min →
      </Button>
      <Button variant="secondary" href="#how" class="hero-cta-secondary">
        Voir comment ça marche ↓
      </Button>
    </div>

    <!-- Stats grid -->
    <div
      class="reveal"
      style="display: grid;
             grid-template-columns: repeat(3, 1fr);
             gap: 0;
             border: 1px solid var(--border);"
      id="stats-grid"
    >
      {stats.map((s, i) => (
        <div
          style={`padding: 32px 24px;
                  ${i < stats.length - 1 ? 'border-right: 1px solid var(--border);' : ''}
                  display: flex; flex-direction: column; align-items: center; gap: 12px;
                  class="hero-stat-card"`}
        >
          <!-- Valeur numérique avec compteur animé -->
          <div style="font-family: 'Syne', sans-serif; font-size: clamp(36px, 5vw, 56px); font-weight: 800; line-height: 1; color: var(--text); display: flex; align-items: baseline; gap: 2px;">
            {s.prefix && <span style="font-size: 0.55em; color: var(--text-secondary);">{s.prefix}</span>}
            <span
              class="counter"
              data-target={s.value}
              data-duration="1500"
            >0</span>
            <span style="font-size: 0.5em; color: var(--text-secondary);">{s.suffix}</span>
          </div>
          <!-- Label -->
          <p style="font-size: 10px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); line-height: 1.4; max-width: 140px;">
            {s.label}
          </p>
        </div>
      ))}
    </div>

    <p class="reveal" style="font-size: 14px; line-height: 1.6; color: var(--text-muted); margin-top: 24px;">
      *Basé sur les benchmarks RAG L1 mesurés sur docs Firecrawl, Linear et Sentry.
      Résultats variables selon la qualité de la documentation client.
    </p>
  </div>
</section>

<style>
  /* Mesh gradient background */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 20% 30%, rgba(6, 182, 212, 0.15) 0%, transparent 20%),
      radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.15) 0%, transparent 20%),
      radial-gradient(circle at 40% 40%, rgba(6, 182, 212, 0.1) 0%, transparent 15%),
      radial-gradient(circle at 60% 60%, rgba(139, 92, 246, 0.1) 0%, transparent 15%);
    background-size: 400% 400%;
    animation: meshGradient 12s ease infinite;
  }
  @keyframes meshGradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-bg {
      animation: none;
    }
  }

  /* Badge */
  .badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border: 1px solid transparent;
    background: linear-gradient(var(--bg-elevated), var(--bg-elevated)) padding-box,
                var(--accent-gradient) border-box;
    border-radius: 4px;
    box-shadow: 0 0 8px 2px rgba(6, 182, 212, 0.4);
    color: var(--text);
    margin-left: 8px;
    vertical-align: middle;
  }

  /* Hero gradient text */
  .hero-gradient {
    color: var(--text);
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Stat cards glassmorphism */
  .hero-stat-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid var(--accent);
  }
  /* Ensure the stat cards have proper padding and hover effect */
  .hero-stat-card:hover {
    border-color: var(--accent-secondary);
    box-shadow: 0 0 12px 4px rgba(139, 92, 246, 0.2);
  }

  /* CTA buttons */
  .hero-cta-primary {
    background: var(--accent-gradient);
    color: var(--bg);
    border: none;
    box-shadow: 0 0 8px 2px rgba(6, 182, 212, 0.4);
    transition: all 0.2s ease;
  }
  .hero-cta-primary:hover {
    box-shadow: 0 0 12px 4px rgba(6, 182, 212, 0.6);
    transform: scale(1.02);
  }
  .hero-cta-primary:active {
    transform: scale(0.98);
  }
  .hero-cta-secondary {
    border: 1px solid var(--border);
    color: var(--text);
    background: transparent;
    transition: all 0.2s ease;
  }
  .hero-cta-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 8px 2px rgba(6, 182, 212, 0.2);
  }
  .hero-cta-secondary:active {
    transform: scale(0.98);
  }

  /* Mobile : stats en colonne */
  @media (max-width: 640px) {
    #stats-grid {
      grid-template-columns: 1fr !important;
    }
    #stats-grid > div {
      border-right: none !important;
      border-bottom: 1px solid var(--border);
    }
    #stats-grid > div:last-child {
      border-bottom: none;
    }
    /* Reduce hero top padding on mobile */
    #hero {
      padding-top: 80px !important;
      padding-bottom: 80px !important;
    }
    /* Adjust badge and text sizes on mobile */
    .badge {
      font-size: 10px;
      padding: 1px 6px;
    }
    h1 {
      font-size: clamp(36px, 10vw, 52px) !important;
    }
  }

.hero-h1 {
  text-wrap: balance;
  line-height: 1.15;
  max-width: 18ch;
}
</style>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    // Compteurs animés — se déclenchent une seule fois au premier scroll-in du stats grid
    const statsGrid = document.getElementById('stats-grid');
    const counters  = document.querySelectorAll('.counter');

    let animated = false;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !animated) {
          animated = true;
          observer.disconnect();

          counters.forEach((counter) => {
            const el       = counter as HTMLElement;
            const target   = parseInt(el.dataset.target || '0', 10);
            const duration = parseInt(el.dataset.duration || '1500', 10);
            const start    = performance.now();

            function tick(now: number) {
              const elapsed  = now - start;
              const progress = Math.min(elapsed / duration, 1);
              // Ease-out cubic
              const eased    = 1 - Math.pow(1 - progress, 3);
              el.textContent = String(Math.round(eased * target));
              if (progress < 1) requestAnimationFrame(tick);
            }

            requestAnimationFrame(tick);
          });
        }
      },
      { threshold: 0.4 }
    );

    if (statsGrid) observer.observe(statsGrid);
  } else {
    // Reduced motion : affiche la valeur finale directement
    document.querySelectorAll('.counter').forEach((el) => {
      const e = el as HTMLElement;
      e.textContent = e.dataset.target || '0';
    });
  }
</script>