---
/**
 * Routing.astro — Tableau de routing par score de confiance.
 * 3 lignes apparaissent en cascade (0 / 150 / 300ms) au scroll-in.
 * Barre verticale pulsante à gauche de chaque ligne.
 * Palette 100% monochrome — pas de couleurs rouge/jaune/vert.
 */

const rows = [
  {
    score: '> 0.75',
    action: 'Réponse automatique directe au client, sources citées',
    badge: 'AUTO-RÉSOLU',
    intensity: 'var(--score-high)',    // blanc
    barOpacity: '1',
  },
  {
    score: '0.50 – 0.75',
    action: 'Note interne à l\'agent avec suggestion IA + sources',
    badge: 'SUGGESTION AGENT',
    intensity: 'var(--score-mid)',     // gris moyen
    barOpacity: '0.6',
  },
  {
    score: '< 0.50',
    action: 'Escalade silencieuse vers la file humaine, aucune trace IA',
    badge: 'ESCALADE HUMAINE',
    intensity: 'var(--score-low)',     // gris foncé
    barOpacity: '0.35',
  },
];
---

<section id="routing" class="section" style="border-top: 1px solid var(--border);">
  <div class="container">

    <p class="eyebrow reveal">INTELLIGENCE DE ROUTING</p>

    <h2
      class="heading-display reveal"
      style="font-size: clamp(36px, 5vw, 64px); line-height: 1.05; margin-bottom: 24px; margin-top: 16px; max-width: 680px;"
    >
      Le système sait quand ne pas répondre
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary); max-width: 680px; margin-bottom: 64px;"
    >
      Un score de confiance composite décide de l'action après chaque génération.
      Aucune réponse incorrecte n'est jamais envoyée au client.
      Le seuil est paramétrable par client.
    </p>

    <!-- Tableau routing -->
    <div class="reveal" style="border: 1px solid var(--border); overflow: hidden; max-width: 860px;">

      <!-- Header -->
      <div style="display: grid; grid-template-columns: 120px 1fr 180px; padding: 14px 24px;
                  background: var(--bg-elevated); border-bottom: 1px solid var(--border);">
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">Score</span>
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">Action</span>
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); text-align: right;">Résultat</span>
      </div>

      <!-- Lignes en cascade -->
      {rows.map((row, i) => (
        <div
          class="routing-row"
          data-delay={i * 150}
          style={`position: relative;
                  display: grid; grid-template-columns: 120px 1fr 180px;
                  padding: 20px 24px; gap: 16px; align-items: center;
                  ${i < rows.length - 1 ? 'border-bottom: 1px solid var(--border);' : ''}
                  opacity: 0; transform: translateX(-8px);
                  transition: opacity 400ms ease, transform 400ms cubic-bezier(0.16, 1, 0.3, 1);`}
        >
          <!-- Barre pulsante gauche -->
          <div
            aria-hidden="true"
            style={`position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
                    background: ${row.intensity};
                    opacity: ${row.barOpacity};
                    animation: pulse-bar 2s ease-in-out infinite;
                    animation-delay: ${i * 300}ms;`}
          ></div>

          <!-- Score -->
          <span style={`font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 600; color: ${row.intensity};`}>
            {row.score}
          </span>

          <!-- Action -->
          <span style="font-size: 14px; color: var(--text-secondary); line-height: 1.5;">
            {row.action}
          </span>

          <!-- Badge résultat -->
          <div style="display: flex; justify-content: flex-end;">
            <span style={`display: inline-block; padding: 5px 10px;
                          font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em;
                          border: 1px solid ${row.intensity};
                          color: ${row.intensity};
                          white-space: nowrap;`}>
              {row.badge}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Note paramétrabilité -->
    <p
      class="reveal"
      style="margin-top: 24px; font-size: 13px; color: var(--text-muted);"
    >
      Les seuils 0.75 et 0.50 sont configurables par client lors de l'onboarding.
      Tous les choix de routing sont auditables dans les logs.
    </p>

  </div>
</section>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rows = document.querySelectorAll('.routing-row') as NodeListOf<HTMLElement>;

  if (!prefersReduced) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          rows.forEach((row) => {
            const delay = parseInt(row.dataset.delay || '0', 10);
            setTimeout(() => {
              row.style.opacity = '1';
              row.style.transform = 'translateX(0)';
            }, delay);
          });
        }
      },
      { threshold: 0.2 }
    );

    if (rows[0]) observer.observe(rows[0].closest('div') as Element);
  } else {
    // Reduced motion : affiche tout immédiatement
    rows.forEach((row) => {
      row.style.opacity = '1';
      row.style.transform = 'translateX(0)';
    });
  }
</script>

<style>
  /* Responsive mobile : colonnes empilées */
  @media (max-width: 640px) {
    .routing-row,
    .routing-row + div {
      grid-template-columns: 1fr !important;
      gap: 8px !important;
    }
    /* Header masqué sur mobile */
    .routing-header { display: none !important; }
  }
</style>
