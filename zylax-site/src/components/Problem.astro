---
/**
 * Problem.astro — Le coût caché du support de niveau 1.
 * Tableau chiffré + punchline ROI.
 */

const rows = [
  { metric: 'Volume mensuel de tickets',              value: '~ 800' },
  { metric: 'Temps moyen par ticket L1',              value: '12 minutes' },
  { metric: 'Coût agent support (chargé)',             value: '35 € / heure' },
  { metric: 'Coût mensuel total',                     value: '~ 5 600 €',           strong: true },
  { metric: 'Part automatisable (questions répétitives)', value: '65 – 70 %' },
  { metric: 'Économie potentielle si automatisé',     value: '3 600 – 3 900 € / mois', strong: true },
];
---

<section id="problem" class="section" style="border-top: 1px solid var(--border);">
  <div class="container">

    <p class="eyebrow reveal">LE PROBLÈME</p>

    <h2
      class="heading-display reveal"
      style="font-size: clamp(36px, 5vw, 64px); line-height: 1.05; margin-bottom: 32px; margin-top: 16px;"
    >
      Le coût caché du support de niveau 1
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary); margin-bottom: 64px;"
    >
      Toute entreprise SaaS B2B qui dépasse 200 clients fait face au même mur. 70&nbsp;% des tickets
      sont des questions répétitives&nbsp;: où trouver tel paramètre, comment configurer telle intégration,
      pourquoi telle erreur. La documentation existe — mais personne ne la lit. Vos agents passent leurs
      journées à copier-coller des réponses standards.
    </p>

    <!-- Tableau chiffré -->
    <div
      class="reveal"
      style="border: 1px solid var(--border); overflow: hidden; max-width: 680px;"
    >
      <!-- Header -->
      <div style="display: grid; grid-template-columns: 1fr auto; padding: 14px 24px;
                  background: var(--bg-elevated); border-bottom: 1px solid var(--border);">
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">Métrique</span>
        <span style="font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">Valeur</span>
      </div>

      {rows.map((row, i) => (
        <div
          style={`display: grid; grid-template-columns: 1fr auto; padding: 16px 24px; gap: 24px;
                  align-items: center;
                  ${i < rows.length - 1 ? 'border-bottom: 1px solid var(--border);' : ''}
                  ${row.strong ? 'background: var(--bg-elevated);' : ''}`}
        >
          <span style={`font-size: 14px; ${row.strong ? 'font-weight: 500; color: var(--text);' : 'color: var(--text-secondary);'}`}>
            {row.metric}
          </span>
          <span style={`font-size: 14px; white-space: nowrap; text-align: right;
                        ${row.strong ? 'font-family: Syne, sans-serif; font-weight: 700; font-size: 15px; color: var(--text);' : 'color: var(--text-secondary);'}`}>
            {row.value}
          </span>
        </div>
      ))}
    </div>

    <!-- Punchline ROI -->
    <p
      class="reveal"
      style="margin-top: 48px; font-size: 18px; font-weight: 500; color: var(--text);
             line-height: 1.5;
             border-left: 2px solid var(--border-strong);"
    >
      À 490&nbsp;€&nbsp;/ mois facturé, le ROI tombe le premier mois.
      Pas dans six mois — <span style="color: var(--text-secondary); font-weight: 400;">dans 30 jours.</span>
    </p>

  </div>
</section>
