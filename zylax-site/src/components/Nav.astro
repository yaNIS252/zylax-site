---
/**
 * Nav.astro — Navigation fixe en haut de page.
 * Desktop : logo gauche, liens centre, CTA droite.
 * Mobile : logo gauche, burger droite → panel full-screen.
 */
import Logo from './Logo.astro';
import Button from './ui/Button.astro';

const links = [
  { label: 'Produit',  href: '#how' },
  { label: 'Tarifs',   href: '#pricing' },
  { label: 'FAQ',      href: '#faq' },
  { label: 'Confidentialité', href: '/privacy' },
  { label: 'Conditions', href: '/terms' },
  { label: 'Contact',  href: '#about' },
];

const CALENDLY = 'https://calendly.com/zylaxyanis/new-meeting';
---

<header
  id="nav"
  role="banner"
  style="position: fixed; top: 0; left: 0; right: 0; z-index: 100;
         height: 64px;
         background: rgba(10,10,10,0.85);
         backdrop-filter: blur(12px);
         -webkit-backdrop-filter: blur(12px);
         border-bottom: 1px solid var(--border);
         display: flex; align-items: center;"
>
  <div class="container" style="width: 100%; display: flex; align-items: center; justify-content: space-between;">

    <!-- Logo -->
    <a href="/" aria-label="Zylax — Accueil" style="display: flex; align-items: center; flex-shrink: 0;">
      <Logo height={32} />
    </a>

    <!-- Liens desktop -->
    <nav aria-label="Navigation principale" style="display: none;" id="nav-links-desktop">
      <ul style="display: flex; gap: 32px; list-style: none; margin: 0; padding: 0;">
        {links.map(l => (
          <li>
            <a
              href={l.href}
              style="font-size: 14px; font-weight: 400; color: var(--text-secondary); text-decoration: none; transition: color 150ms ease;"
              onmouseover="this.style.color='var(--text)'"
              onmouseout="this.style.color='var(--text-secondary)'"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA desktop + burger mobile -->
    <div style="display: flex; align-items: center; gap: 12px;">
      <div id="nav-cta-desktop" style="display: none;">
        <Button variant="primary" href={CALENDLY} target="_blank" rel="noopener noreferrer">
          Réserver une démo →
        </Button>
      </div>

      <!-- Burger — visible seulement sur mobile -->
      <button
        id="burger"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        style="display: flex; flex-direction: column; justify-content: center; gap: 5px;
               width: 40px; height: 40px; padding: 8px; background: none; border: none;
               cursor: pointer;"
      >
        <span class="burger-line" style="display: block; height: 1.5px; background: var(--text); transition: transform 250ms ease, opacity 150ms ease;"></span>
        <span class="burger-line" style="display: block; height: 1.5px; background: var(--text); transition: transform 250ms ease, opacity 150ms ease;"></span>
        <span class="burger-line" style="display: block; height: 1.5px; background: var(--text); transition: transform 250ms ease, opacity 150ms ease;"></span>
      </button>
    </div>
  </div>
</header>

<!-- Menu mobile full-screen -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Menu navigation"
  style="position: fixed; inset: 0; z-index: 99;
         background: var(--bg);
         display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 8px;
         transform: translateX(100%);
         transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);"
>
  <nav aria-label="Navigation mobile">
    <ul style="list-style: none; margin: 0; padding: 0; text-align: center; display: flex; flex-direction: column; gap: 8px;">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class="mobile-nav-link"
            style="display: block; font-family: 'Syne', sans-serif; font-size: clamp(28px, 8vw, 40px); font-weight: 700; letter-spacing: -0.02em;
                   color: var(--text-secondary); text-decoration: none; padding: 8px 24px;
                   transition: color 150ms ease;"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div style="margin-top: 32px;">
    <Button variant="primary" href={CALENDLY} target="_blank" rel="noopener noreferrer">
      Réserver une démo →
    </Button>
  </div>
</div>

<style>
  /* Responsive : affiche liens desktop et CTA desktop à partir de 1024px */
  @media (min-width: 1024px) {
    #nav-links-desktop  { display: block !important; }
    #nav-cta-desktop    { display: block !important; }
    #burger             { display: none !important; }
  }

  /* Hover liens nav mobile */
  .mobile-nav-link:hover { color: var(--text) !important; }
</style>

<script>
  const burger      = document.getElementById('burger');
  const mobileMenu  = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    mobileMenu!.style.transform = 'translateX(0)';
    burger!.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';

    // Anime les barres en X
    const lines = burger!.querySelectorAll('.burger-line') as NodeListOf<HTMLElement>;
    lines[0].style.transform = 'translateY(6.5px) rotate(45deg)';
    lines[1].style.opacity   = '0';
    lines[2].style.transform = 'translateY(-6.5px) rotate(-45deg)';
  }

  function closeMenu() {
    isOpen = false;
    mobileMenu!.style.transform = 'translateX(100%)';
    burger!.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    const lines = burger!.querySelectorAll('.burger-line') as NodeListOf<HTMLElement>;
    lines[0].style.transform = '';
    lines[1].style.opacity   = '1';
    lines[2].style.transform = '';
  }

  burger?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());

  // Ferme le menu quand on clique un lien
  mobileLinks.forEach(link => link.addEventListener('click', closeMenu));

  // Ferme sur Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
