---
import Button from './ui/Button.astro';

const plans = [
  {
    name: 'Starter',
    monthly: 490,
    install: 249,
    annual: 420,
    recommended: false,
    stripeMonthly: 'https://buy.stripe.com/4gMdRacV21jH2dL6y93VC00'
  },
  {
    name: 'Pro',
    monthly: 790,
    install: 490,
    annual: 670,
    recommended: true,
    stripeMonthly: 'https://buy.stripe.com/4gM5kEg7ebYlaKh4q13VC03'
  },
  {
    name: 'Premium',
    monthly: 1190,
    install: 700,
    annual: 990,
    recommended: false,
    stripeMonthly: 'https://buy.stripe.com/6oU3cw4owd2pdWt8Gh3VC05'
  }
];
---

<section id="pricing" class="section" style="border-top: 1px solid var(--border);">
  <div class="container">

    <p class="eyebrow reveal">TARIFS TRANSPARENTS</p>

    <h2
      class="heading-display reveal"
      style="font-size: clamp(36px, 5vw, 64px); line-height: 1.05; margin-bottom: 24px; margin-top: 16px; max-width: 600px;"
    >
      Choisissez le plan adapté à votre échelle
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary);
             max-width: 500px; margin: 0 auto 24px;"
    >
      Des forfaits clairs, sans surprise. Optez pour le mensuel sans engagement ou l'engagement 12 mois pour économiser 2 mois.
    </p>

    {/* Toggle mensuel / 12 mois */}
    <div class="reveal" id="pricing-toggle" style="display: flex; justify-content: center; gap: 16px; margin-bottom: 24px;">
      <button
        id="toggle-monthly"
        class="toggle-btn"
        style="flex: 1; padding: 12px 24px; font-size: 15px; font-weight: 500; border: 1px solid var(--border); background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 150ms ease;"
      >
        Mensuel
      </button>
      <button
        id="toggle-annual"
        class="toggle-btn"
        style="flex: 1; padding: 12px 24px; font-size: 15px; font-weight: 500; border: 1px solid var(--border); background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 150ms ease;"
      >
        Engagement 12 mois
      </button>
    </div>

    {/* Cards */}
    <div class="reveal" style="display: grid; gap: 24px;">
      {plans.map((plan) => (
        <div
          key={plan.name}
          class="pricing-card"
          style="
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            background: var(--bg);
            display: flex;
            flex-direction: column;
          "
        >
          {/* Badge recommandé */}
          {plan.recommended && (
            <span style="
              align-self: flex-start;
              margin: 12px;
              padding: 2px 8px;
              font-size: 11px;
              font-weight: 500;
              text-transform: uppercase;
              letter-spacing: 0.1em;
              border: 1px solid var(--border);
              color: var(--text);
              background: rgba(255,255,255,0.05);
            ">
              RECOMMANDÉ
            </span>
          )}

          <div style="flex: 1; display: flex; flex-direction: column; padding: 24px;">
            <h3 style="
              font-family: 'Syne', sans-serif;
              font-size: 20px;
              font-weight: 600;
              color: var(--text);
              margin: 0 0 12px 0;
            ">
              {plan.name}
            </h3>

            {/* Prix */}
            <div style="
              display: flex;
              flex-direction: column;
              align-items: flex-start;
              margin-bottom: 16px;
            ">
              <span class="price-annual" style="
                font-family: 'Syne', sans-serif;
                font-size: 28px;
                font-weight: 700;
                color: var(--text);
                display: block;
              ">
                {plan.annual} €
              </span>
              <span class="price-monthly" style="
                font-family: 'Syne', sans-serif;
                font-size: 28px;
                font-weight: 700;
                color: var(--text);
                display: none;
              ">
                {plan.monthly} €
              </span>
              <span style="
                font-size: 14px;
                color: var(--text-secondary);
                margin-top: 4px;
                display: block;
              ">/mois</span>
            </div>

            {/* Frais d'installation */}
            <div class="install-fee" style="
              font-size: 14px;
              color: var(--text-secondary);
              margin-bottom: 16px;
              display: none;
            ">
              + {plan.install} € frais d'installation uniques
            </div>

            {/* Note économies */}
            <p style="
              font-size: 14px;
              color: var(--text-secondary);
              font-style: italic;
              margin-bottom: 20px;
              display: block;
            ">
              Économisez 2 mois
            </p>

            {/* CTA */}
            <Button
              variant="primary"
              href="#" /* placeholder, will be set via JS */
              style="align-self: flex-start; width: fit-content;"
            >
              Choisir ce plan
            </Button>
          </div>
        </div>
      ))}
    </div>

    {/* Mention légale sous les cards */}
    <p
      class="reveal"
      style="margin-top: 24px; font-size: 14px; color: var(--text-muted); line-height: 1.6;"
    >
      TVA non applicable, art. 293 B du CGI. Résiliation mensuel : préavis 30 jours. Engagement 12 mois : non résiliable avant terme.
    </p>

  </div>
</section>

<style>
  /* Toggle button active state */
  .toggle-btn.active {
    background: var(--bg-elevated);
    color: var(--text);
    border-color: var(--border);
  }

  /* Pricing card hover effect */
  .pricing-card:hover {
    border-color: var(--accent);
  }

  /* Toggle views: default shows annual (12 mois) */
  .price-annual { display: block; }
  .price-monthly { display: none; }
  .install-fee { display: none; }

  /* When monthly toggle active */
  .toggle-monthly .price-annual { display: none; }
  .toggle-monthly .price-monthly { display: block; }
  .toggle-monthly .install-fee { display: block; }
</style>

<script>
  // Get toggle buttons and container
  const monthlyBtn = document.getElementById('toggle-monthly');
  const annualBtn = document.getElementById('toggle-annual');
  const pricingRoot = document.getElementById('pricing'); // section root

  // Set initial view: annual (12 mois) active
  annualBtn.classList.add('active');
  // Initialize annual view href/text
  setView(false);

  // Function to switch view
  function setView(showMonthly) {
    if (showMonthly) {
      pricingRoot.classList.add('toggle-monthly');
      monthlyBtn.classList.add('active');
      annualBtn.classList.remove('active');
      // Update CTA hrefs and text
      document.querySelectorAll('.pricing-card').forEach((card, index) => {
        const plan = plans[index];
        const btn = card.querySelector('button'); // Button component renders as <button>
        if (btn) {
          btn.href = plan.stripeMonthly;
          btn.textContent = 'Souscrire →';
        }
      });
    } else {
      pricingRoot.classList.remove('toggle-monthly');
      monthlyBtn.classList.remove('active');
      annualBtn.classList.add('active');
      // Update CTA hrefs and text for annual
      document.querySelectorAll('.pricing-card').forEach((card, index) => {
        const plan = plans[index];
        const btn = card.querySelector('button');
        if (btn) {
          btn.href = 'mailto:yanis@zylax.fr';
          btn.textContent = 'Nous contacter →';
        }
      });
    }
  }

  // Event listeners
  monthlyBtn.addEventListener('click', () => setView(true));
  annualBtn.addEventListener('click', () => setView(false));

  // Optional: keyboard accessibility
  monthlyBtn.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      setView(true);
    }
  });
  annualBtn.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      setView(false);
    }
  });
</script>