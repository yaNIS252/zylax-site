---
import Button from './ui/Button.astro';

const plans = [
  {
    name: 'Starter',
    monthly: 490,
    annual: 420,
    setup: 249,
    recommended: false,
    stripeMonthly: 'https://buy.stripe.com/4gMdRacV21jH2dL6y93VC00',
    features: [
      { label: 'Sources doc', value: '1' },
      { label: 'Volume tickets', value: '500/mois' },
      { label: 'Canaux', value: 'Zendesk' },
      { label: 'Routing IA', value: 'Auto + escalade' },
      { label: 'Langues', value: 'Mono-langue' },
      { label: 'Ré-ingestion', value: 'Manuelle' },
      { label: 'SLA réponse', value: '—' },
      { label: 'Reporting', value: 'Mensuel' },
      { label: 'Onboarding', value: 'Standard' },
      { label: 'Accès API', value: 'Non' },
    ]
  },
  {
    name: 'Pro',
    monthly: 790,
    annual: 720,
    setup: 490,
    recommended: true,
    stripeMonthly: 'https://buy.stripe.com/4gM5kEg7ebYlaKh4q13VC03',
    features: [
      { label: 'Sources doc', value: 'Jusqu\'à 3' },
      { label: 'Volume tickets', value: 'Illimité' },
      { label: 'Canaux', value: 'Zendesk + Intercom' },
      { label: 'Routing IA', value: 'Auto + suggestion' },
      { label: 'Langues', value: 'Mono-langue' },
      { label: 'Ré-ingestion', value: 'Mensuelle auto' },
      { label: 'SLA réponse', value: '24h' },
      { label: 'Reporting', value: 'Mensuel' },
      { label: 'Onboarding', value: 'Standard' },
      { label: 'Accès API', value: 'Non' },
    ]
  },
  {
    name: 'Premium',
    monthly: 1190,
    annual: 990,
    setup: 700,
    recommended: false,
    stripeMonthly: 'https://buy.stripe.com/6oU3cw4owd2pdWt8Gh3VC05',
    features: [
      { label: 'Sources doc', value: 'Illimitées' },
      { label: 'Volume tickets', value: 'Illimité' },
      { label: 'Canaux', value: 'Zendesk + Intercom' },
      { label: 'Routing IA', value: 'Auto + suggestion' },
      { label: 'Langues', value: 'Multi-langues' },
      { label: 'Ré-ingestion', value: 'Mensuelle auto' },
      { label: 'SLA réponse', value: '4h' },
      { label: 'Reporting', value: 'Hebdomadaire' },
      { label: 'Onboarding', value: 'Dédié' },
      { label: 'Accès API', value: 'Oui' },
    ]
  }
];
---

<section id="pricing" class="section" style="border-top: 1px solid var(--border);">
  <div class="container">

    <p class="eyebrow reveal">TARIFS TRANSPARENTS</p>

    <h2
      class="heading-display reveal"
    >
      Choisissez le plan adapté à votre échelle
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary);
             max-width: 500px; margin: 0 auto 24px;"
    >
      Des forfaits clairs, sans surprise. Optez pour le mensuel sans engagement ou l'engagement 12 mois pour économiser 2 mois.
    </p>

    {/* Cards */}
    <div class="reveal" style="display: grid; gap: 24px;">
      {plans.map((plan, index) => (
        <div
          key={plan.name}
          class="pricing-card"
          style="
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            position: relative;
            isolation: isolate;
          "
        >
          {/* Badge recommandé */}
          {plan.recommended && (
            <span style="
              position: absolute;
              top: 8px;
              left: 8px;
              padding: 4px 10px;
              font-size: 11px;
              font-weight: 500;
              text-transform: uppercase;
              letter-spacing: 0.1em;
              border: 1px solid var(--accent);
              color: var(--accent);
              background: rgba(6,182,212,0.1);
              backdrop-filter: blur(4px);
            ">
              RECOMMANDÉ
            </span>
          )}

          <div style="flex: 1; display: flex; flex-direction: column; padding: 32px 24px 24px 24px;">
            <h3 style="
              font-family: 'Syne', sans-serif;
              font-size: 20px;
              font-weight: 600;
              color: var(--text);
              margin: 0 0 16px 0;
            ">
              {plan.name}
            </h3>

            {/* Prix principal */}
            <div class="price-wrapper" style="display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 20px;">
              {/* Prix mensuel */}
              <div class="price monthly" style="
                font-family: 'Syne', sans-serif;
                font-size: 32px;
                font-weight: 800;
                color: var(--accent);
                margin-bottom: 4px;
              ">
                {plan.monthly}€
              </div>
              <span class="price-suffix monthly" style="
                font-size: 14px;
                color: var(--text-secondary);
                margin-bottom: 4px;
              ">/mois</span>

              {/* Frais d'installation */}
              {plan.setup > 0 && (
                <div class="install-fee monthly" style="
                  font-size: 13px;
                  color: var(--text-secondary);
                  margin-top: 4px;
                ">
                  + {plan.setup}€ frais de setup
                </div>
              )}

              {/* Note annuelle */}
              <div class="annual-note" style="
                font-size: 13px;
                color: var(--text-muted);
                margin-top: 8px;
                line-height: 1.4;
              ">
                Profitez de 2 mois offerts avec un engagement de 12 mois ({plan.annual}€/mois, sans frais de setup)
              </div>
            </div>

            {/* Features table */}
            <div class="features-table" style="margin-top: 24px;">
              {plan.features.map((feat, fidx) => (
                <div key={fidx} style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-top: 1px solid rgba(255,255,255,0.04);">
                  <span style="font-size: 13px; color: var(--text-muted);">{feat.label}</span>
                  <span
                    style={{
                      fontWeight: 500,
                      color: feat.value === 'Oui' || feat.value === 'Non' ?
                        (feat.value === 'Oui' ? 'var(--accent)' : 'var(--text-muted)') :
                        feat.value === '—' ?
                          'var(--text-muted)' :
                          feat.value.match(/h$/) || feat.value.match(/mois$/) || feat.value.match(/€/) ?
                            'var(--accent)' :
                            'var(--text)'
                    }}
                  >
                    {feat.value}
                  </span>
                </div>
              ))}
              {/* Hide first border-top */}
              <style>
                .features-table > div:first-child { border-top: none; }
              </style>
            </div>

            {/* CTA */}
            <Button
              variant="primary"
              href={plan.stripeMonthly}
              class="pricing-cta"
              style="align-self: stretch; margin-top: 24px;"
            >
              Choisir ce plan
            </Button>
          </div>
        </div>
      ))}
    </div>

    {/* Mention légale sous les cards */}
    <p
      class="reveal"
      style="margin-top: 24px; font-size: 14px; color: var(--text-muted); line-height: 1.6;"
    >
      TVA non applicable, art. 293 B du CGI. Résiliation mensuel : préavis 30 jours. Engagement 12 mois : non résiliable avant terme.
    </p>

  </div>
</section>

<style>
  /* Ensure three cards side-by-side on desktop, stack on mobile */
  @media (min-width: 768px) {
    .reveal[style*="display: grid;"] {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  /* On mobile, default grid is 1fr (already) */
</style>