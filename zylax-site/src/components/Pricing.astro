---
/**
 * Pricing.astro — Grille tarifaire transparente
 * Présente le forfait unique et ses inclusions
 */

const features = [
  { icon: '🇪🇺', label: 'Hébergement européen (France/UE)', description: 'Données toujours dans l\'espace juridique européen, conformité RGPD intégrée' },
  { icon: '📊', label: 'Volume illimité de tickets', description: 'Pas de frais supplémentaires selon le nombre de tickets traités' },
  { icon: '👥', label: 'Équipes illimitées', description: 'Ajoutez autant d\'agents et de départements que nécessaire' },
  { icon: '⚙️', label: 'Personnalisation avancée', description: 'Configuration du routing, seuils personnalisables, règles métier' },
  { icon: '🔄', label: 'Mises à jour continues', description: 'Améliorations régulières du moteur IA et des connecteurs' },
  { icon: '🛡️', label: 'Support technique inclus', description: 'Assistance dédiée pour l\'onboarding et le fonctionnement quotidien' },
  { icon: '🔌', label: 'Connecteurs prémium', description: 'Intégrations natives Zendesk, Intercom, et API webhook personnalisée' },
  { icon: '📈', label: 'Analytics & Reporting', description: 'Tableau de bord des économies générées et performance du système' }
];

const faq = [
  {
    question: 'Y a-t-il des frais d\'installation ou de mise en place ?',
    answer: 'Non, le forfait de 300€/mois inclus l\'installation complète, la configuration initiale et la formation de votre équipe.'
  },
  {
    question: 'Le prix change-t-il si mon volume de tickets augmente ?',
    answer: 'Absolument pas. Le forfait reste fixe quel que soit le nombre de tickets traités, même si votre volume double ou triple.'
  },
  {
    question: 'Y a-t-il un engagement minimum ou une durée de contrat ?',
    answer: 'Non, vous pouvez annuler à tout moment avec un préavis de 30 jours. Nous croyons que notre valeur doit parler d\'elle-même chaque mois.'
  },
  {
    question: 'Que se passe-t-il si je dépasse les limites raisonnables d\'usage ?',
    answer: 'Nous travaillons avec nos clients pour optimiser l\'usage. En cas de besoins exceptionnels, nous discutons d\'une solution sur mesure plutôt que d\'appliquer des pénalités.'
  },
  {
    question: 'Le prix inclut-il la formation et l\'accompagnement ?',
    answer: 'Oui, l\'onboarding complet est inclus : configuration technique, formation des administrators et ateliers d\'adoption pour les équipes support.'
  }
];
---

<section id="pricing" class="section" style="border-top: 1px solid var(--border);">
  <div class="container">

    <p class="eyebrow reveal">TARIFS TRANSPARENTS</p>

    <h2
      class="heading-display reveal"
      style="font-size: clamp(36px, 5vw, 64px); line-height: 1.05; margin-bottom: 24px; margin-top: 16px; max-width: 600px;"
    >
      Un forfait unique pour une prévisibilité totale
    </h2>

    <p
      class="reveal"
      style="font-size: 18px; line-height: 1.7; color: var(--text-secondary); max-width: 500px; margin-bottom: 48px;"
    >
      Chez Zylax, nous croyons en la simplicité et la transparence. Pas de frais cachés, pas de surprises, pas de complexité inutile.
      Un seul forfait qui inclut tout ce dont vous avez besoin pour automatiser votre support client.
    </p>

    {/* Price Card */}
    <div class="reveal" style="border: 1px solid var(--border); border-radius: 12px; overflow: hidden; max-width: 400px;">
      {/* Header */}
      <div style="background: var(--bg-elevated); border-bottom: 1px solid var(--border); padding: 24px; text-align: center;">
        <h3 style="font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 600; color: var(--text); margin: 0 0 8px 0;">
          Forfait Unique
        </h3>
        <p style="font-size: 16px; color: var(--text-secondary); margin: 0;">
          Tout inclus · Engagement mensuel
        </p>
      </div>

      {/* Price */}
      <div style="background: var(--bg); padding: 32px 24px; text-align: center;">
        <div style="font-family: 'Syne', sans-serif; font-size: 48px; font-weight: 700; color: var(--text); line-height: 1;">
          300
        </div>
        <div style="font-size: 18px; color: var(--text-secondary); margin-top: 8px;">
          € / mois
        </div>
      </div>

      {/* Footer */}
      <div style="background: var(--bg-elevated); border-top: 1px solid var(--border); padding: 24px; text-align: center;">
        <p style="font-size: 14px; color: var(--text-muted); margin: 0;">
          Annulable à tout moment · Aucun frais d'installation
        </p>
      </div>
    </div>

    {/* Features List */}
    <div class="reveal" style="display: grid; gap: 16px; margin-top: 48px;">
      {features.map((feature, i) => (
        <div key={i} style="display: flex; align-items: flex-start; gap: 12px; padding: 16px 0; border-top: 1px solid var(--border);">
          <div style="flex-shrink: 0; font-size: 20px;">
            {feature.icon}
          </div>
          <div>
            <h4 style="font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 600; color: var(--text); margin: 0 0 4px 0;">
              {feature.label}
            </h4>
            <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.5; margin: 0;">
              {feature.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    {/* FAQ Accordion */}
    <div class="reveal" style="margin-top: 48px; border-top: 1px solid var(--border);">
      <h3 style="font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 600; color: var(--text); margin: 0 0 16px 0; padding: 24px 0; border-bottom: 1px solid var(--border);">
        Questions fréquentes
      </h3>

      {faq.map((item, i) => (
        <div key={i} style="border-bottom: 1px solid var(--border);">
          <div style="padding: 20px 24px; cursor: pointer; display: flex; justify-content: space-between; align-items: center;"
               onmouseover="this.style.backgroundColor='var(--bg-elevated)'"
               onmouseout="this.style.backgroundColor='transparent'"
          >
            <div>
              <p style="font-size: 15px; font-weight: 500; color: var(--text); margin: 0;">
                {item.question}
              </p>
            </div>
            <div style="font-size: 18px; color: var(--text-muted); transition: transform 200ms ease;">
              {/* This would normally be interactive, but for simplicity we'll show it expanded */}
              ▼
            </div>
          </div>
          <div style="padding: 0 24px 20px 24px; max-height: 0; overflow: hidden; transition: max-height 300ms ease;">
            <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6; margin: 0;">
              {item.answer}
            </p>
          </div>
        </div>
      ))}
    </div>

    {/* CTA */}
    <div class="reveal" style="margin-top: 32px; text-align: center;">
      <p style="font-size: 18px; color: var(--text-secondary); max-width: 500px; margin: 0 auto 24px;">
        Prêt à simplifier votre facturation tout en augmentant votre efficacité ?
      </p>
      {/* Button would go here - but we'll add it in index.astro when we import this component */}
    </p>

  </div>
</section>